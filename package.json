{
	"name": "gantt-master",
	"version": "0.1.0",
	"description": "Timeline, Kanban, and Table views for Obsidian Bases.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"dev:watch": "node scripts/watch.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"timeline",
		"kanban",
		"table",
		"bases",
		"gantt",
		"multiview"
	],
	"author": "donganhvu",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "24.6.1",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "^0.27.4",
		"esbuild-wasm": "^0.25.10",
		"obsidian": "latest",
		"tslib": "2.8.1",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"html2canvas": "^1.4.1"
	}
}
